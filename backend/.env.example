# Backend (Express)
NODE_ENV=development
PORT=5000

# Required
MONGODB_URI=mongodb://127.0.0.1:27017/med-ai-simulator
JWT_SECRET=replace-with-a-strong-secret
JWT_EXPIRES_IN=7d

# Comma-separated allowed client origins
CLIENT_ORIGINS=http://localhost:3000,http://localhost:3001

# Optional integrations
GOOGLE_CLIENT_ID=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
AISHA_API_KEY=

# Email service (for OTP)
GMAIL_USER=
GMAIL_APP_PASSWORD=
