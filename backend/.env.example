# Backend (Express)
NODE_ENV=development
PORT=5000

# Required
MONGODB_URI=mongodb://127.0.0.1:27017/med-ai-simulator
JWT_SECRET=replace-with-a-strong-secret
JWT_EXPIRES_IN=7d

# Comma-separated allowed client origins
CLIENT_ORIGINS=http://localhost:3000,http://localhost:3001

# Optional integrations
GOOGLE_CLIENT_ID=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
AISHA_API_KEY=
# Muxlisa AI (Uzbek STT/TTS) — https://muxlisa.uz
MUXLISA_API_KEY=
MUXLISA_SPEAKER_MALE=1
MUXLISA_SPEAKER_FEMALE=2

# Email service (for OTP)
GMAIL_USER=
GMAIL_APP_PASSWORD=

# Public site URL (used in payment return URLs)
FRONTEND_URL=http://localhost:3000

# Payment gateways — leave blank to keep gateways disabled (manual confirm only).
# Click
CLICK_SERVICE_ID=
CLICK_MERCHANT_ID=
CLICK_SECRET_KEY=
# Payme
PAYME_MERCHANT_ID=
PAYME_MERCHANT_KEY=

# Telegram bot (manual balance top-up approval)
TELEGRAM_BOT_TOKEN=
# Comma-separated admin Telegram numeric ids
TELEGRAM_ADMIN_IDS=
# Public admin panel URL used in Telegram message links
ADMIN_PANEL_URL=http://localhost:3000/admin

# Support bot (user-facing) — @Med_AI_Simulator_Supportbot
SUPPORT_BOT_TOKEN=
# Telegram chat id that support messages are forwarded to
SUPPORT_FORWARD_CHAT_ID=

# Subscription prices (so'm)
PRICE_MONTHLY=60000
PRICE_YEARLY=550000
PRICE_YEARLY_OLD=720000

# Referral reward per successfully referred sign-up
REFERRAL_BONUS=1000
REFERRAL_POINTS=5

# DigitalOcean Spaces (S3-compatible) — file uploads.
# Leave blank to fall back to local disk storage (backend/public/uploads).
SPACES_KEY=
SPACES_SECRET=
SPACES_REGION=sfo3
SPACES_ENDPOINT=https://sfo3.digitaloceanspaces.com
SPACES_BUCKET=med-ai-simulator
SPACES_PUBLIC_URL=https://med-ai-simulator.sfo3.digitaloceanspaces.com
