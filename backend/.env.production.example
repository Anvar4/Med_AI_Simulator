# ─────────────────────────────────────────────────────────────
# PRODUCTION .env namunasi (DigitalOcean serverda ishlatish uchun)
# Serverda: cp .env.production.example .env  → keyin qiymatlarni to'ldiring.
# Bu fayl GIT'ga kiradi (namuna), lekin haqiqiy .env hech qachon kirmaydi.
# ─────────────────────────────────────────────────────────────

NODE_ENV=production
PORT=5000

# ── Ma'lumotlar bazasi (MongoDB Atlas) ──
MONGODB_URI=mongodb+srv://USER:PAROL@CLUSTER.mongodb.net/med_ai_simulator
JWT_SECRET=kuchli-maxfiy-kalit-bu-yerga
JWT_EXPIRES_IN=7d

# ── CORS: frontend domeni(lar)i, vergul bilan ──
# Frontend Vercel'da bo'lsa: https://medaisimulator.uz
# Frontend shu serverda bo'lsa: http://SERVER_IP yoki domen
CLIENT_ORIGINS=https://medaisimulator.uz,https://www.medaisimulator.uz

# ── Public URL'lar (xabar/qaytish havolalari uchun) ──
FRONTEND_URL=https://medaisimulator.uz
ADMIN_PANEL_URL=https://medaisimulator.uz/admin

# ── OpenAI (AI baholash + chat) ──
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ── Google OAuth ──
GOOGLE_CLIENT_ID=

# ── Email (OTP yuborish) ──
GMAIL_USER=
GMAIL_APP_PASSWORD=

# ── Aisha / Muxlisa (TTS/STT, ixtiyoriy) ──
AISHA_API_KEY=
MUXLISA_API_KEY=
MUXLISA_SPEAKER_MALE=1
MUXLISA_SPEAKER_FEMALE=0

# ── Telegram bot (bitta bot: to'lov + support) ──
# @Med_AI_Simulator_Supportbot tokeni:
SUPPORT_BOT_TOKEN=
# Eski to'lov boti tokeni (ixtiyoriy, fallback):
TELEGRAM_BOT_TOKEN=
# Admin Telegram numeric id(lar) — vergul bilan:
TELEGRAM_ADMIN_IDS=
SUPPORT_FORWARD_CHAT_ID=

# ── DigitalOcean Spaces (fayl yuklash) ──
SPACES_KEY=
SPACES_SECRET=
SPACES_REGION=sfo3
SPACES_ENDPOINT=https://sfo3.digitaloceanspaces.com
SPACES_BUCKET=med-ai-simulator
SPACES_PUBLIC_URL=https://med-ai-simulator.sfo3.digitaloceanspaces.com

# ── Obuna narxlari (so'm) ──
PRICE_MONTHLY=60000
PRICE_YEARLY=550000
PRICE_YEARLY_OLD=720000

# ── Referal mukofoti ──
REFERRAL_BONUS=1000
REFERRAL_POINTS=5
