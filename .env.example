# Frontend (Next.js)
# Backend API base URL with /api suffix
NEXT_PUBLIC_API_URL=http://localhost:5000/api

# Google OAuth client id for frontend login button
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# BioDigital Human Developer Key
# Olish: https://developer.biodigital.com/ -> My Apps -> Allowed Domains ro'yxatiga
# localhost, 127.0.0.1 va production domeningizni qo'shing, keyin shu kalitni ko'chiring
NEXT_PUBLIC_BIODIGITAL_DK=
