# Frontend (Next.js)
# Backend API base URL with /api suffix
NEXT_PUBLIC_API_URL=http://localhost:5000/api

# Google OAuth client id for frontend login button
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# SEO — Search Console / Webmaster tasdiqlash kodlari (meta-teg usuli)
# Google Search Console: https://search.google.com/search-console
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
# Yandex Webmaster: https://webmaster.yandex.com
NEXT_PUBLIC_YANDEX_SITE_VERIFICATION=

# 3D simulator endi to'liq kod asosida (Three.js) ishlaydi — tashqi API/kalit kerak emas.
